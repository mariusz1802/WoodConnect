{% extends 'w3desAdminBundle::layout.html.twig' %}
{% trans_default_domain "admin" %}
{% block page_title %}
Zapisy
{% endblock %}
{% block content %}
<h1>
    {{ block('page_title') }}
</h1>
<p>
    <div id="grid"></div>
</p>
{% endblock %}
{% block javascripts %}
{{ parent() }}
<script type="text/javascript">
$(function() {
    $('#grid').jsGrid({
        width: '100%',
        filtering: true,
        sorting: true,
        paging: true,
        editing: true,
        autoload: true,
        deleteConfirm: function(item) {
            return "Czy na pewno chcesz to zrobić?";
        },
        onItemEditing : function(args) {
            window.location = '{{url("admin.records.edit", { id : '@id@' })|raw}}'.replace(/@id@/g, args.item.id);
            args.cancel = true;
        },
        onItemEditing : function(args) {
            window.location = '{{url("admin.records.edit", { id : '@id@' })|raw}}'.replace(/@id@/g, args.item.id);
            args.cancel = true;
        },
        onItemDeleted : function(args) {
            window.location = '{{url("admin.records.remove", { id : '@id@' })|raw}}'.replace(/@id@/g, args.item.id);
            args.cancel = true;
        },
        pageLoading: true,
        controller : {
            loadData : function(filter) {
                var d = jQuery.Deferred();
                $.ajax({
                    url : '{{url("admin.records.json")}}',
                    dataType : 'json',
                    data : filter
                }).done(function(response) {
                    d.resolve(response);
                });

                return d.promise();
            }
        },
        fields : [
            {name : 'name', title: 'Imię i nazwisko', type : 'text'},
            {name : 'phone', title: 'Telefon', type : 'text'},
            {name : 'email', title: 'E-mail', type : 'text'},
            {name : 'practiceName', title: 'Nazwa praktyki', type : 'text'},
            {name: 'createdAt', title: 'Data utworzenia', 'type' : 'date'},
            {type : 'control'}
        ]
    });
});

</script>

{% endblock %}